# Default local coordd action policy.
#
# This governs preflight checks for local commands before an agent executes
# them. Destructive actions are blocked by default. Everything else can be
# tightened into an explicit allowlist by switching guard mode to enforce.

segment guard_enforce {
    guard.mode == "enforce"
}

segment guard_advisory {
    guard.mode == "advisory"
}

segment repo_mutation {
    action.writes_repo == true
    or action.writes_filesystem == true
    or action.writes_coord == true
}

segment read_only_action {
    action.writes_repo == false
    and action.writes_filesystem == false
    and action.writes_coord == false
    and action.network == false
}

segment network_read_action {
    action.network == true
    and action.writes_repo == false
    and action.writes_filesystem == false
    and action.writes_coord == false
}

rule DestructiveAction priority 0 {
    when {
        action.destructive == true
        and action.allowlisted == false
    }
    then HardBlock {
        code: "destructive_action",
        reason: "destructive action is not allowlisted",
        profile: "blocked",
    }
}

rule RepoRequired priority 10 {
    when {
        action.requires_repo == true
        and repo.present == false
    }
    then HardBlock {
        code: "repo_required",
        reason: "action requires an open graft repository",
        profile: "blocked",
    }
}

rule ActiveAgentRequired priority 20 {
    when segment repo_mutation {
        action.writes_repo == true
        and guard.require_active_agent == true
        and session.active_agent == false
    }
    then HardBlock {
        code: "active_agent_required",
        reason: "repo-mutating action requires an active coordination agent",
        profile: "blocked",
    }
}

rule GovernedSubprocessAllowlist priority 25 {
    when segment guard_enforce {
        process.origin != ""
        and action.default_allowed == false
        and action.allowlisted == false
    }
    then HardBlock {
        code: "governed_subprocess_not_allowlisted",
        reason: "governed subprocess action is not on the coordd allowlist",
        profile: "blocked",
    }
}

rule AllowlistEnforced priority 30 {
    when segment guard_enforce {
        action.default_allowed == false
        and action.allowlisted == false
    }
    then HardBlock {
        code: "not_allowlisted",
        reason: "action is not on the coordd allowlist",
        profile: "blocked",
    }
}

# ---- Coordination-aware rules (require coord.active) ----

rule ConflictingEntityWrite priority 5 {
    when {
        action.writes_repo == true
        and coord.active == true
        and coord.conflicting_claims_count > 0
    }
    then HardBlock {
        code: "conflicting_claim",
        reason: "file claimed by another agent — coordinate or wait",
        profile: "blocked",
    }
}

rule StaleAgentWrite priority 6 {
    when {
        action.writes_repo == true
        and coord.active == true
        and coord.last_heartbeat_age_s > 120
    }
    then HardBlock {
        code: "stale_agent",
        reason: "agent heartbeat expired — re-register with graft workon",
        profile: "blocked",
    }
}

rule UnreadConflictsWrite priority 35 {
    when {
        action.writes_repo == true
        and coord.active == true
        and coord.unread_conflicts > 0
    }
    then Advisory {
        code: "unread_conflicts",
        reason: "unread coordination events — check feed before proceeding",
        profile: "repo_write",
    }
}

rule PresenceOverlapWrite priority 36 {
    when {
        action.writes_filesystem == true
        and coord.active == true
        and coord.presence_overlap_count > 0
    }
    then Advisory {
        code: "presence_overlap",
        reason: "another agent is reading files you are about to modify",
        profile: "repo_write",
    }
}

rule WatchedEntityWrite priority 37 {
    when {
        action.writes_repo == true
        and coord.active == true
        and coord.watching_claims_count > 0
    }
    then Advisory {
        code: "watched_entity",
        reason: "file is watched by another agent — they will be notified",
        profile: "repo_write",
    }
}

rule AdvisoryReadOnly priority 40 {
    when segment guard_advisory {
        action.default_allowed == false
        and action.allowlisted == false
        and action.writes_repo == false
        and action.writes_filesystem == false
        and action.writes_coord == false
        and action.network == false
    }
    then Advisory {
        code: "not_allowlisted",
        reason: "action is not on the coordd allowlist",
        profile: "read_only",
    }
}

rule AdvisoryRepoWrite priority 41 {
    when segment guard_advisory {
        action.default_allowed == false
        and action.allowlisted == false
        and (action.writes_repo == true or action.writes_filesystem == true or action.writes_coord == true)
        and action.network == false
    }
    then Advisory {
        code: "not_allowlisted",
        reason: "action is not on the coordd allowlist",
        profile: "repo_write",
    }
}

rule AdvisoryNetworkRead priority 42 {
    when segment guard_advisory {
        action.default_allowed == false
        and action.allowlisted == false
        and action.network == true
        and action.writes_repo == false
        and action.writes_filesystem == false
        and action.writes_coord == false
    }
    then Advisory {
        code: "not_allowlisted",
        reason: "action is not on the coordd allowlist",
        profile: "network_read",
    }
}

rule AdvisoryRepoWriteNetwork priority 43 {
    when segment guard_advisory {
        action.default_allowed == false
        and action.allowlisted == false
        and action.network == true
        and (action.writes_repo == true or action.writes_filesystem == true or action.writes_coord == true)
    }
    then Advisory {
        code: "not_allowlisted",
        reason: "action is not on the coordd allowlist",
        profile: "repo_write_network",
    }
}

rule AllowReadOnly priority 900 {
    when segment read_only_action { true }
    then Allow {
        code: "allow",
        reason: "action is allowed by coordd policy",
        profile: "read_only",
    }
}

rule AllowRepoWrite priority 910 {
    when segment repo_mutation {
        action.network == false
    }
    then Allow {
        code: "allow",
        reason: "action is allowed by coordd policy",
        profile: "repo_write",
    }
}

rule AllowNetworkRead priority 920 {
    when segment network_read_action { true }
    then Allow {
        code: "allow",
        reason: "action is allowed by coordd policy",
        profile: "network_read",
    }
}

rule AllowRepoWriteNetwork priority 930 {
    when {
        action.network == true
        and (action.writes_repo == true or action.writes_filesystem == true or action.writes_coord == true)
    }
    then Allow {
        code: "allow",
        reason: "action is allowed by coordd policy",
        profile: "repo_write_network",
    }
}

rule DefaultAllow priority 999 {
    when {
        true
    }
    then Allow {
        code: "allow",
        reason: "action is allowed by coordd policy",
        profile: "read_only",
    }
}
